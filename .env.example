# NeuroRx AI — Environment configuration template
#
# Copy this file to .env and fill in all values before running any phase.
# See setup/00_workspace_runbook.md for step-by-step instructions on where to find each value.
#
# Variables with defaults (can be omitted; uncomment to override):
#   CATALOG, SCHEMA_*, VOLUME_RAW, VECTOR_INDEX_FULLNAME
#
# Required variables (must be set; no defaults):
#   DATABRICKS_HOST, DATABRICKS_TOKEN, VECTOR_SEARCH_ENDPOINT, FM_CHAT_ENDPOINT,
#   FM_GUARDRAIL_ENDPOINT, LAKEBASE_HOST, LAKEBASE_DB, LAKEBASE_USER, LAKEBASE_PASSWORD

# ============================================================================
# DATABRICKS WORKSPACE (required)
# ============================================================================

# Workspace URL: visible in your browser's address bar while logged into Databricks.
# Format: https://dbc-[alphanumeric].cloud.databricks.com
# From: setup/00_workspace_runbook.md §5
DATABRICKS_HOST=https://dbc-xxxxxxxx-xxxx.cloud.databricks.com

# Personal access token for API access.
# From: Databricks UI > your user icon (top-right) > Settings > Developer > Access tokens > Generate new token
# Never commit this value; keep it in .env (which is in .gitignore).
DATABRICKS_TOKEN=dapi0123456789abcdef

# ============================================================================
# UNITY CATALOG (defaults shown; rarely need override)
# ============================================================================

# Catalog name (default: "neurorx").
# From: Databricks UI > Catalog (left-nav) > Catalogs > your catalog name
# CATALOG=neurorx

# Schema names (auto-derived from CATALOG as {catalog}.{layer}, unless overridden).
# All should exist after running setup/01_uc_setup.sql
# SCHEMA_BRONZE=neurorx.bronze
# SCHEMA_SILVER=neurorx.silver
# SCHEMA_GOLD=neurorx.gold
# SCHEMA_APP=neurorx.app
# SCHEMA_EVALS=neurorx.evals

# Raw file landing volume (default: "neurorx.bronze.raw_files").
# From: Databricks UI > Catalog > Volumes > neurorx.bronze.raw_files
# VOLUME_RAW=neurorx.bronze.raw_files

# ============================================================================
# VECTOR SEARCH / AI SEARCH (required)
# ============================================================================

# AI Search endpoint name (this endpoint serves the drug_knowledge_index).
# From: Databricks UI > Compute > AI Search tab, or Serving left-nav (pay-per-token list)
# Created by pipelines/05_vector_index.py (Task 1.7), which fixes this name to "neurorx-vs".
VECTOR_SEARCH_ENDPOINT=neurorx-vs

# Full name of the Vector Search index (default: "neurorx.gold.drug_knowledge_index").
# From: Phase 1 pipeline output, or Catalog > Tables > neurorx.gold.drug_knowledge_index
# VECTOR_INDEX_FULLNAME=neurorx.gold.drug_knowledge_index

# ============================================================================
# FOUNDATION MODEL APIs — PAY-PER-TOKEN ENDPOINTS (required)
# ============================================================================

# Claude chat endpoint for the supervisor agent.
# From: Databricks UI > Serving (left-nav), or Playground (top-right) > model dropdown
# Must be a live pay-per-token endpoint. Examples: databricks-claude-sonnet-5, databricks-claude-opus-4-8
# See setup/00_workspace_runbook.md §2 for the full list of available Claude endpoints.
FM_CHAT_ENDPOINT=databricks-claude-sonnet-5

# Haiku-tier Claude endpoint for the post-generation guardrail (lightweight LLM-judge).
# From: same as FM_CHAT_ENDPOINT (Serving or Playground)
# Examples: databricks-claude-haiku-4-5
FM_GUARDRAIL_ENDPOINT=databricks-claude-haiku-4-5

# ============================================================================
# LAKEBASE / OLTP (required)
# ============================================================================

# Lakebase instance host — a per-project Databricks endpoint, NOT a name you
# choose. Verified against current docs (Task 3.1, see lakebase/README.md):
# shaped like ep-abc-123.databricks.com. Get it from the Lakebase project's
# "Connect" page (use its "copy psql connection snippet" button).
LAKEBASE_HOST=ep-abc-123.databricks.com

# Lakebase database name. Verified (Task 3.1): every Lakebase project has a
# database literally named "databricks_postgres" — this is not a per-project
# choice, use this value as-is.
LAKEBASE_DB=databricks_postgres

# Lakebase username. This project uses native Postgres password auth for
# local dev (see lakebase/README.md's auth-method comparison) — create a role
# via `CREATE ROLE neurorx_dev LOGIN PASSWORD '...'` after enabling "Enable
# Postgres Native Role Login" on the instance, then use that role name here.
# (The alternative, OAuth-token auth via generate_database_credential(),
# expires hourly — the wrong shape for a .env value.)
LAKEBASE_USER=neurorx_dev

# Password for the role above. Never commit this value; keep it in .env
# (already in .gitignore).
LAKEBASE_PASSWORD=your_lakebase_password_here
